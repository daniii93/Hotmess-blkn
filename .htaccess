DirectoryIndex index.php index.html
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php

<FilesMatch "^(migrate-.*|debug-.*|reset-admin|change-admin-password|create-test-member|simulate-ticket-purchase)\.php$">
  Require all denied
</FilesMatch>

RewriteEngine On
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
RewriteRule ^app/?$ app-page.php [L,QSA]
RewriteRule ^app/concierge/?$ app-concierge.php [L,QSA]
RewriteRule ^app/(events|tickets|hotels|packages|map|offers|profile)/?$ app-section.php?section=$1 [L,QSA]
RewriteRule ^events/([^/]+)/?$ event-detail.php?slug=$1 [L,QSA]
RewriteRule ^events/?$ events.php [L,QSA]
RewriteRule ^signup/?$ register.php [L,QSA]
RewriteRule ^feed/?$ feed.php [L,QSA]
RewriteRule ^friends/?$ friends.php [L,QSA]
RewriteRule ^notifications/?$ notifications.php [L,QSA]
RewriteRule ^settings/?$ settings.php [L,QSA]
RewriteRule ^scanner/?$ scanner.php [L,QSA]
RewriteRule ^u/([^/]+)/?$ public-user-profile.php?username=$1 [L,QSA]
RewriteRule ^events/([^/]+)/preview/?$ event-detail.php?slug=$1&preview=1 [L,QSA]
RewriteRule ^events/([^/]+)/checkout/?$ payment-checkout.php?event=$1 [L,QSA]
RewriteRule ^events/([^/]+)/waitlist/?$ event-waitlist.php?slug=$1 [L,QSA]
RewriteRule ^tickets/?$ tickets.php [L,QSA]
RewriteRule ^hotels/([^/]+)/?$ hotel-detail.php?slug=$1 [L,QSA]
RewriteRule ^hotels/?$ hotels.php [L,QSA]
RewriteRule ^travel/?$ travel.php [L,QSA]
RewriteRule ^packages/([^/]+)/?$ package-detail.php?slug=$1 [L,QSA]
RewriteRule ^packages/?$ packages.php [L,QSA]
RewriteRule ^community/ambassadors/?$ community-ambassadors.php [L,QSA]
RewriteRule ^community/?$ community.php [L,QSA]
RewriteRule ^membership/(plus|black)/?$ membership-detail.php?slug=$1 [L,QSA]
RewriteRule ^membership/?$ membership.php [L,QSA]
RewriteRule ^chat/([0-9]+)/?$ chat.php?conversation=$1 [L,QSA]
RewriteRule ^chat/?$ chat.php [L,QSA]
RewriteRule ^profile/?$ profile.php [L,QSA]
RewriteRule ^account/(profile|tickets|events|hotels|packages|benefits|rewards|referrals|concierge|settings)/?$ account-section.php?section=$1 [L,QSA]
RewriteRule ^account/membership/?$ account-membership.php [L,QSA]
