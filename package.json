{
  "name": "hotmess-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "dev": "next dev",
    "build": "next build",
    "test": "echo \"Tests are prepared in tests/e2e and tests/unit\"",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load/ticket-reservation.js",
    "launch:check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "env:validate": "powershell -ExecutionPolicy Bypass -File scripts/validate-env.ps1",
