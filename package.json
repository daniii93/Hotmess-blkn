    "@tanstack/react-query": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "framer-motion": "latest",
    "html5-qrcode": "latest",
    "lucide-react": "latest",
    "next": "15.5.19",
    "next-intl": "latest",
    "qrcode": "latest",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-email": "latest",
    "react-hook-form": "latest",
    "react-onesignal": "latest",
    "resend": "latest",
    "stripe": "latest",
