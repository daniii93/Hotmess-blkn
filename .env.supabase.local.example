# Copy this file to .env.supabase.local and replace the placeholders.
# .env.supabase.local is ignored by git and stays only on this computer.

# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Replace [YOUR-PASSWORD] with the real database password.
POSTGRES_URL_NON_POOLING="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"
